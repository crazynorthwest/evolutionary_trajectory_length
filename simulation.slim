function(numeric)CreateMutationLibrary(void){
	fileName = addPath()+"/mutation/"+filenamenumber+".dat";
	header = "ID mutsize "+(paste(rep("traitValue",n)+1:n,sep=" "));
	writeFile(fileName,header);
	library = matrix(rep(0.0,genome_size*n),ncol=n);
	for(i in 0:(genome_size-1)){
		x = rnorm(n);
		rx = rexp(n,lambda);
		deltaZ= rx*x/sqrt(sum(x*x));
		library[i,]=deltaZ;
		writeFile(fileName,paste(c(i,rx,deltaZ),sep=" "),T);
	}
	return library;
}

function (void)getPhenotype(object<Subpopulation> subpop) {
	for (ind in subpop.individuals){
		for (mutType in sim.mutationTypes){
			Z = rep(0.0,n);
			for (mutation in ind.haploidGenome1.mutationsOfType(mutType)){
				Z = Z + (mutation.getValue("deltaZ"))/2;
			}
			for (mutation in ind.haploidGenome2.mutationsOfType(mutType)){
				Z = Z + (mutation.getValue("deltaZ"))/2;
			}
			for (sub in sim.substitutions[sim.substitutions.mutationType == mutType]){
				Z = Z + sub.getValue("deltaZ");
			}
			distanceOptimal = getDistance(Z,Optimal = Optimal_list[sim.cycle-1,]);
			ind.fitnessScaling = exp(-q*distanceOptimal^m);
			ind.setValue("indFitness", ind.fitnessScaling);
			for (i in 0:(n-1)){
				ind.setValue("phenotype"+i, Z[i]);
			}
		}
	}
}

function (numeric)getDistance(numeric Phenotype, numeric Optimal) {
	distance =	(sum((Phenotype - Optimal)^2))^(1/2);
	return distance;
}
function (numeric)EuclideanDistanceInd(object<Individual> ind1, object<Individual> ind2){
	a = NULL;
	b = NULL;
	for (i in 0:(n-1)){
		a = c(a, ind1.getValue("phenotype"+i));
		b = c(b, ind2.getValue("phenotype"+i));
	}
	distance2 = sum((a-b)^2);
	return distance2;
}

function (void)outputData(object<Subpopulation> subpop) {
	result_rec = NULL;
	result_mean = NULL;
	result_var = NULL;
	ind_fitness = NULL;
	for(idx in 0:(n-1)){
		result_rec_ind = NULL;
		for (ind in subpop.individuals){
			result_rec_ind=c(result_rec_ind,ind.getValue("phenotype"+idx));
		}
		result_mean = c(result_mean, mean(result_rec_ind));
		result_var = c(result_var, var(result_rec_ind));
	}
	for (ind in subpop.individuals){
		ind_fitness=c(ind_fitness,ind.getValue("indFitness"));
	}
	fitness_mean = mean(ind_fitness);
	fitness_var = var(ind_fitness);
	FST = calcFST(p1.haplosomes,p2.haplosomes);
	fileName = addPath()+"/result/data_phe"+filenamenumber+".dat";
	writeFile(fileName,paste(c(sim.cycle, result_mean, result_var, fitness_mean, fitness_var,subpop.name,FST),sep=" "),T);
}

1: mutation(){
	//a mutation "undoing" a previous mutation (back to phenotype of rep(0,n)) is given a F tag value, and T otherwise
	info = mutation_library[mut.position,];
	if(any(haplosome.mutations.position==mut.position)){
		if(haplosome.mutations[haplosome.mutations.position==mut.position].tag){
			mut.setMutationType(1);
			mut.setValue("deltaZ",rep(0,n));
			mut.tag=0;
		} else {
			mut.setMutationType(1);
			mut.setValue("deltaZ",info);
			mut.tag=1;
		}
	}else{
		mut.setMutationType(1);
		mut.setValue("deltaZ",info);
		mut.tag=1;
	}
	return T;
}
4998 modifyChild(){
