4999 mateChoice(p3){
	while(1>0){
		mate=sample(p3.individuals,1);
		if(mate.tag != individual.tag){break;}
	}
	return mate;
}

// set up a simple neutral simulation
initialize() {
	addParameter();
	defineConstant("mutation_library", CreateMutationLibrary());
	initializeMutationRate(1e-6);
	// m1 mutation type: neutral
	initializeMutationType("m1", 0.5, "f", 0.0);
	mutationTypes = m1;
	m1.convertToSubstitution=F;
	m1.mutationStackPolicy="l";
	// g1 genomic element type: uses m1 for all mutations
	initializeGenomicElementType("g1", m1, 1.0);
	initializeGenomicElement(g1,0,genome_size-1);
	initializeRecombinationRate(c(1e-6,0.5,1e-6,0.5,1e-6,0.5,1e-6,0.5,1e-6),asInteger(c(genome_size/5-1, genome_size/5, 2*genome_size/5-1, 2*genome_size/5, 3*genome_size/5-1, 3*genome_size/5, 4*genome_size/5-1, 4*genome_size/5, genome_size-1)));
	fileName_phe = addPath()+"/result/data_phe"+filenamenumber+".dat";
	writeFile(fileName_phe,paste(c("generation", rep("mean_phe",n)+1:n, rep("var_phe",n)+1:n, "fitness_mean", "fitness_var", "population_id", "FST"),sep=" "),T);
	fileName_mut = addPath()+"/result/data_p1_mut"+filenamenumber+".dat";
	writeFile(fileName_mut,paste(c("generation", rep("mut",genome_size)+1:genome_size),sep=" "),T);
	fileName_mut = addPath()+"/result/data_p2_mut"+filenamenumber+".dat";
	writeFile(fileName_mut,paste(c("generation", rep("mut",genome_size)+1:genome_size),sep=" "),T);
}

1 early() {
	sim.addSubpop("p1", K);
	sim.addSubpop("p2", K);
}

1: late(){
	getPhenotype(p1);
	outputData(p1);
	mut_positions = p1.haplosomes.mutations.position;
	mut_fre = tabulate(mut_positions, genome_size-1) /(2 * p1.individualCount);
	fileName_mut = addPath()+"/result/data_p1_mut"+filenamenumber+".dat";
	writeFile(fileName_mut,paste(c(sim.cycle,mut_fre),sep=" "),T);
	getPhenotype(p2);
	outputData(p2);
	mut_positions = p2.haplosomes.mutations.position;
	mut_fre_2 = tabulate(mut_positions, genome_size-1) /(2 * p2.individualCount);
	fileName_mut = addPath()+"/result/data_p2_mut"+filenamenumber+".dat";
	writeFile(fileName_mut,paste(c(sim.cycle,mut_fre),sep=" "),T);
}
4998 early(){
	sim.addSubpop("p3", 2*K);
	p3.setMigrationRates(c(p1,p2), c(0.5,0.5));
}
4999 early(){
	p3.setMigrationRates(c(p1,p2), c(0.0,0.0));
}
4998: late() {
	getPhenotype(p3);
	outputData(p3);
	p3.individuals.fitnessScaling = 1.0;
}
5000 late() {
	sim.simulationFinished();
	fileName_ind = addPath()+"/result/data_ind.dat";
	for(idx in 0:(2*K-1)){
		writeFile(fileName_ind, paste(c(asFloat(filenamenumber), p3.individuals[idx].getValue("phenotype0")), sep=" "),T);
	}
}